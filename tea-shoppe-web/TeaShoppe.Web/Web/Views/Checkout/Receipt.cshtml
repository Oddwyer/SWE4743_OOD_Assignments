@model TeaShoppe.Web.Web.ViewModels.CheckoutViewModel

@* View for Checkout results. *@
<div class="page-header">
    <h1>Sweet Teas</h1>
    <h3>@(Model.Success ? "Order Receipt" : "Purchase Issue")</h3>
</div>

<div class="receipt-card">
    <p class="receipt-message">@Html.Raw(Model.Message.Replace("\n", "<br/>"))</p>
    @if (Model.Success)
    {
        <p>Payment Method: <strong>@Model.PaymentType</strong></p>
    }
    <p>
        <a class="return-link" asp-controller="Inventory" asp-action="Search">Return to Search</a>
    </p>
</div>